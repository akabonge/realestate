# ─────────────────────────────────────────────────────────────────────
#  Rappahannock Realty Group — Scout AI Environment Variables
#  Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────────────────

# Anthropic Claude API (optional — if set, Claude is used instead of Ollama)
# Get a key at: https://console.anthropic.com
ANTHROPIC_API_KEY=

# Which Claude model to use (only relevant if ANTHROPIC_API_KEY is set)
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Ollama settings (used when ANTHROPIC_API_KEY is not set)
OLLAMA_MODEL=llama3.2
OLLAMA_BASE_URL=http://localhost:11434

# ChromaDB storage path (relative to project root)
CHROMA_PERSIST_PATH=./chroma_store

# Sentence-transformers model for local embeddings
EMBEDDING_MODEL=all-MiniLM-L6-v2

# RAG settings
MAX_RETRIEVED_CHUNKS=6
MAX_HISTORY_MESSAGES=12

# Lead storage (JSON file — relative to project root)
LEADS_FILE=./leads.json
